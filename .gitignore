# capacitor / iOS build artifacts
#
# `ios/App/App/public/` is regenerated on every `npx cap sync ios`
# — it's the Next static export (`out/`) copied into the bundle.
# `ios/App/output/` is Xcode's build output. The rest of `ios/`
# IS committed: the Xcode project, Swift sources, and (on
# Capacitor 8+) the SPM `Package.swift` manifest.
#
# Capacitor 8 uses Swift Package Manager instead of CocoaPods, so
# there is no `ios/App/Pods/` directory to ignore anymore. The
# historical ignore pattern is kept as a comment in case a
# `cap migrate` downgrade ever reinstates CocoaPods.
# (historical: ios/App/Pods/)
ios/App/App/public/
ios/App/output/

# Day 6 engine audit harness outputs (raw bet PII / full Sonnet response).
# scripts/audit-engine.ts re-fetches from Supabase + re-runs runAutopsy
# on demand, so neither file needs to live in the repo.
scripts/audit-bets.json
scripts/audit-output.json

# One-off verification harnesses: re-fetch from Supabase on demand and
# emit raw bet/PII to stdout. Source script + the Day 6 audit script
# itself are excluded from the repo for the same reason.
scripts/audit-engine.ts
scripts/test-check-in.ts
