# ── Supabase (required) ──
# Get from: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (required) ──
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Stripe (required for payments, app works without but upgrades disabled) ──
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Get from: dashboard.stripe.com → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=
# Get from: dashboard.stripe.com → Products → Price ID for each product
STRIPE_PRO_PRICE_ID=
STRIPE_SHARP_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_SHARP_ANNUAL_PRICE_ID=

# ── Resend (required for weekly digest emails) ──
# Get from: resend.com → API Keys
RESEND_API_KEY=
# Generate any random string for cron auth (e.g. openssl rand -hex 32)
CRON_SECRET=

# ── Meta Pixel + Conversions API (optional, production ad tracking) ──
# Get Pixel ID from: business.facebook.com → Events Manager → Data Sources
# → your pixel → Settings. Used for both client-side fbq() and server CAPI.
NEXT_PUBLIC_META_PIXEL_ID=
# Get CAPI token from: Events Manager → your pixel → Settings →
# Conversions API → Generate access token. Required for server-side
# CompleteRegistration / Purchase fires in app/auth/callback/route.ts and
# the Stripe webhook.
META_CAPI_TOKEN=

# ── App ──
# Set to your production URL when deploying (e.g. https://betautopsy.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
